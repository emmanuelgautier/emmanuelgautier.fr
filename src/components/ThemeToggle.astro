---
const sunPath =
  'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z'
const moonPath =
  'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z'
---

<button
  type="button"
  aria-label="Toggle dark mode"
  aria-pressed="false"
  class="bg-gray-200 dark:bg-gray-800 rounded p-3 h-10 w-10 cursor-pointer"
  data-theme-toggle
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    stroke="currentColor"
    class="h-4 w-4 text-gray-800 dark:text-gray-200"
    aria-hidden="true"
  >
    <path
      data-theme-toggle-icon
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d={moonPath}
    />
  </svg>
</button>

<script is:inline define:vars={{ sunPath, moonPath }}>
  document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
    const icon = button.querySelector('[data-theme-toggle-icon]')

    function syncIcon() {
      const isDark = document.documentElement.classList.contains('dark')
      button.setAttribute('aria-pressed', String(isDark))
      icon?.setAttribute('d', isDark ? sunPath : moonPath)
    }

    button.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark')
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
      syncIcon()
    })

    syncIcon()
  })
</script>
