---
import { SITE } from '../config/site'
import { t } from '../i18n'

const locale = SITE.locale as 'en' | 'fr'
---

<div class="border border-gray-100 text-center rounded p-6 my-4 w-full dark:border-gray-700 bg-sky-100 dark:bg-sky-800">
  <p class="text-lg md:text-xl font-bold text-gray-900 dark:text-gray-100">
    {t('book-call.cta.title', locale)}
  </p>
  <p class="my-1 text-gray-800 dark:text-gray-200">
    {t('book-call.cta.description', locale)}
  </p>
  <div class="w-full text-center mt-4">
    <a
      href="https://l.emmanuelgautier.com/book-a-call"
      target="_blank"
      rel="nofollow noopener noreferrer"
      class="plausible-event-name=bookACall"
    >
      <button
        type="button"
        class="px-6 py-2 bg-gray-900 hover:bg-gray-100 dark:bg-gray-300 text-gray-100 hover:text-gray-900 dark:text-gray-700 rounded cursor-pointer"
      >
        {t('book-call.cta.button', locale)}
      </button>
    </a>
  </div>
</div>
