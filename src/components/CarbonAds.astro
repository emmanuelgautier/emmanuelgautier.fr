<div id="carbon-container"></div>

<script>
  const container = document.getElementById('carbon-container')
  if (container && !document.getElementById('_carbonads_js')) {
    const script = document.createElement('script')
    script.src =
      '//cdn.carbonads.com/carbon.js?serve=CWYDV27W&placement=wwwemmanuelgautiercom'
    script.id = '_carbonads_js'
    script.async = true
    container.appendChild(script)
  }
</script>
