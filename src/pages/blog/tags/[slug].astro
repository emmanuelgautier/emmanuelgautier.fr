---
import { SITE } from '../../../config/site'
import { t } from '../../../i18n'
import { getAllTags, getTagBySlug, getPostUrl, getSnippetUrl } from '../../../lib/content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import BlogPostCard from '../../../components/BlogPostCard.astro'
import SnippetCard from '../../../components/SnippetCard.astro'

export async function getStaticPaths() {
  const tags = await getAllTags()
  return tags.map((tag) => ({
    params: { slug: tag.slug },
  }))
}

const { slug } = Astro.params
const locale = SITE.locale as 'en' | 'fr'

const tag = await getTagBySlug(slug!)
if (!tag) throw new Error(`Tag not found: ${slug}`)

const posts = tag.posts.sort((a, b) => (a.data.created > b.data.created ? -1 : 1))
const snippets = tag.snippets.sort((a, b) =>
  a.data.created > b.data.created ? -1 : 1
)

const title = tag.name
const description = `Articles about ${tag.name}`
const url = `${SITE.siteUrl}/blog/tags/${slug}`
---

<BaseLayout
  title={title}
  description={description}
  canonical={url}
  class="flex flex-col px-8 justify-center max-w-4xl mx-auto"
>
  <div class="flex flex-col justify-center items-start max-w-2xl mx-auto mb-16">
    <h1 class="text-3xl sm:text-4xl md:text-5xl pt-1 pb-2 md:pb-4 font-bold tracking-wide">
      {title}
    </h1>

    {posts.length > 0 && (
      <section>
        <h2 class="text-xl md:text-2xl py-1 font-bold tracking-wide mb-2">
          {t('posts', locale).charAt(0).toUpperCase() + t('posts', locale).slice(1)}
        </h2>
        {posts.map((post) => (
          <BlogPostCard
            url={getPostUrl(post)}
            title={post.data.title}
            description={post.data.description}
          />
        ))}
      </section>
    )}

    {snippets.length > 0 && (
      <section>
        <h2 class="text-xl md:text-2xl py-1 font-bold tracking-wide mb-2">
          {t('snippets', locale).charAt(0).toUpperCase() + t('snippets', locale).slice(1)}
        </h2>
        {snippets.map((snippet) => (
          <SnippetCard
            url={getSnippetUrl(snippet)}
            title={snippet.data.title}
            description={snippet.data.description}
            icon={snippet.data.image}
          />
        ))}
      </section>
    )}
  </div>
</BaseLayout>
